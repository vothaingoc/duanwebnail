---
import StaffDetail from '../../components/StaffDetail.astro';
import SiteLayout from '../../components/SiteLayout.astro';
import { getStaffMemberBySlug, getStaffMembers } from '../../lib/sanity';

export async function getStaticPaths() {
  const staffMembers = await getStaffMembers();
  return staffMembers.map((staff) => ({
    params: { slug: staff.slug },
    props: { staff },
  }));
}

const { slug } = Astro.params;
const staff = Astro.props.staff || await getStaffMemberBySlug(String(slug));

if (!staff) {
  return Astro.redirect('/staff/');
}

const title = `${staff.name} | スタッフ紹介 | Golyn Nail`;
const description = `${staff.name}（${staff.position}）のプロフィール。経験年数、得意分野、資格、担当デザインをご紹介します。`;
---

<SiteLayout title={title} description={description}>
  <main>
    <section class="detail-hero">
      <StaffDetail staff={staff} />
      <div class="back-actions">
        <a class="btn-primary" data-i18n="staff_back" href="/staff/">スタッフ一覧へ戻る</a>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .detail-hero {
    padding: calc(var(--nav-h) + 54px) 20px 96px;
  }
  .profile {
    display: grid;
    grid-template-columns: minmax(0, 440px) minmax(0, 1fr);
    gap: 54px;
    max-width: 1100px;
    margin: 0 auto;
    align-items: center;
  }
  .profile-image {
    border-radius: 8px;
    overflow: hidden;
    background: var(--cream-mid);
    box-shadow: 0 12px 40px rgba(74,55,40,.12);
  }
  .profile-image img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }
  .profile-position {
    color: var(--gold);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: .22em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .profile h1 {
    font-family: var(--serif);
    font-size: clamp(44px, 8vw, 72px);
    font-weight: 300;
    line-height: 1.08;
    color: var(--brown-deep);
  }
  .profile-facts {
    display: grid;
    gap: 0;
    margin-top: 30px;
    border-top: 1px solid var(--cream-deep);
  }
  .profile-facts div {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 18px;
    padding: 16px 0;
    border-bottom: 1px solid var(--cream-deep);
  }
  .profile-facts dt {
    color: var(--text-light);
    font-size: 12px;
    letter-spacing: .12em;
    font-weight: 400;
  }
  .profile-facts dd {
    color: var(--text);
    font-size: 15px;
  }
  .profile-text {
    margin-top: 26px;
    color: var(--text-mid);
    font-size: 15px;
    line-height: 1.95;
  }
  .staff-gallery {
    max-width: 1100px;
    margin: 84px auto 0;
  }
  .section-heading {
    text-align: center;
    margin-bottom: 30px;
  }
  .section-heading p {
    color: var(--gold);
    font-size: 12px;
    letter-spacing: .26em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .section-heading h2 {
    font-family: var(--serif);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 300;
    color: var(--brown-deep);
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .gallery-grid img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 6px;
    box-shadow: 0 8px 26px rgba(74,55,40,.08);
  }
  .back-actions {
    display: flex;
    justify-content: center;
    margin-top: 54px;
  }
  @media (max-width: 900px) {
    .detail-hero { padding: calc(var(--nav-h) + 34px) 20px 72px; }
    .profile { grid-template-columns: 1fr; gap: 32px; }
    .profile-image { max-width: 520px; width: 100%; margin: 0 auto; }
    .gallery-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .profile-facts div { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
