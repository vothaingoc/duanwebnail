Object.assign(i18n.ja, { price_detail_btn:'詳しい料金表を見る' });
Object.assign(i18n.en, { price_detail_btn:'View Detailed Pricing' });
Object.assign(i18n.vi, { price_detail_btn:'Xem bảng giá chi tiết' });
Object.assign(i18n.zh, { price_detail_btn:'查看详细价格表' });
Object.assign(i18n.ko, { price_detail_btn:'자세한 가격표 보기' });
Object.assign(i18n.my, { price_detail_btn:'အသေးစိတ်စျေးနှုန်းကြည့်ရန်' });
Object.assign(i18n.id, { price_detail_btn:'Lihat harga lengkap' });

/* ═══════════════════════════════
   LANGUAGE ENGINE
═══════════════════════════════ */
let currentLang = '';

const langLabels = { ja:'日本語', en:'English', vi:'Tiếng Việt', zh:'中文', ko:'한국어', my:'မြန်မာ', id:'Bahasa Indonesia' };
const langFlagClasses = { ja:'flag-ja', en:'flag-uk', vi:'flag-vi', zh:'flag-cn', ko:'flag-ko', my:'flag-my', id:'flag-id' };
const pageTitles = {
  ja:'Golyn Nail - Osaka | ネイルアトリエ',
  en:'Golyn Nail - Osaka | Nail Atelier',
  vi:'Golyn Nail - Osaka | Tiệm Nail',
  zh:'Golyn Nail - Osaka | 美甲沙龙',
  ko:'Golyn Nail - Osaka | 네일 살롱',
  my:'Golyn Nail - Osaka | လက်သည်းဆိုင်',
  id:'Golyn Nail - Osaka | Salon Kuku'
};

function setLang(lang) {
  if (lang === currentLang) return;
  if (!i18n[lang]) lang = 'ja';
  currentLang = lang;
  localStorage.setItem('golynLang', lang);

  document.documentElement.lang = { ja:'ja', en:'en', vi:'vi', zh:'zh', ko:'ko', my:'my', id:'id' }[lang] || 'ja';
  document.body.classList.add('lang-switching');

  setTimeout(() => {
    const t = i18n[lang] || i18n.en;
    if (window.GolynPricing) window.GolynPricing.renderHome(lang);

    document.querySelectorAll('[data-i18n]').forEach(el => {
      const k = el.getAttribute('data-i18n');
      if (t[k] !== undefined) el.innerHTML = t[k];
    });
    if (window.GolynPricing) {
      window.GolynPricing.renderServicePrices(lang);
      window.GolynPricing.applyCampaignState();
    }
    document.querySelectorAll('[data-i18n-ph]').forEach(el => {
      const k = el.getAttribute('data-i18n-ph');
      if (t[k] !== undefined) el.placeholder = t[k];
    });

    document.body.classList.remove('lang-switching');
    document.title = pageTitles[lang];

    updateLangPickers(lang);
  }, 170);
}

function updateLangPickers(lang) {
  document.querySelectorAll('.lang-picker').forEach(picker => {
    const flag = picker.querySelector('.lang-current .flag');
    const label = picker.querySelector('.lang-current-label');
    if (flag) flag.className = `flag ${langFlagClasses[lang] || langFlagClasses.ja}`;
    if (label) label.textContent = langLabels[lang] || langLabels.ja;
    picker.querySelectorAll('[data-lang-option]').forEach(option => {
      option.classList.toggle('active', option.dataset.langOption === lang);
    });
  });
}

function closeLangMenus() {
  document.querySelectorAll('.lang-picker.open').forEach(picker => {
    picker.classList.remove('open');
    const button = picker.querySelector('.lang-current');
    if (button) button.setAttribute('aria-expanded', 'false');
  });
}

function toggleLangMenu(button) {
  const picker = button.closest('.lang-picker');
  const shouldOpen = !picker.classList.contains('open');
  closeLangMenus();
  picker.classList.toggle('open', shouldOpen);
  button.setAttribute('aria-expanded', String(shouldOpen));
}

function chooseLang(lang) {
  setLang(lang);
  closeLangMenus();
}

document.addEventListener('click', e => {
  if (!e.target.closest('.lang-picker')) closeLangMenus();
});

/* ═══════════════════════════════
   UI HELPERS
═══════════════════════════════ */
function toggleMenu() {
  const menu = document.getElementById('mobileNav');
  if (!menu) return;
  const isOpen = menu.classList.toggle('open');
  menu.setAttribute('aria-hidden', String(!isOpen));
  document.body.classList.toggle('mobile-nav-open', isOpen);
}

// Scroll reveal
const revealObs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
window.golynRevealObserver = revealObs;
document.querySelectorAll('.fade-up').forEach(el => revealObs.observe(el));

// Navbar shadow on scroll
window.addEventListener('scroll', () => {
  document.getElementById('navbar').style.boxShadow =
    window.scrollY > 40 ? '0 2px 24px rgba(74,55,40,.08)' : 'none';
});

// Gallery: show only some works first, reveal all on button click, and open image preview
const galleryGrid = document.querySelector('.gallery-grid');
const lightbox = document.getElementById('galleryLightbox');
const lightboxImage = document.getElementById('lightboxImage');
const lightboxClose = lightbox ? lightbox.querySelector('.lightbox-close') : null;
const lightboxPrev = lightbox ? lightbox.querySelector('.lightbox-prev') : null;
const lightboxNext = lightbox ? lightbox.querySelector('.lightbox-next') : null;
const lightboxCounter = document.getElementById('lightboxCounter');
let galleryImages = [];
let currentGalleryIndex = 0;
let touchStartX = 0;
let touchStartY = 0;

function refreshHomeGalleryImages() {
  galleryImages = (window.GOLYN_HOME_GALLERY_ITEMS || window.GOLYN_GALLERY_ITEMS || [])
    .slice(0, 8)
    .map(item => item.src);
}

function showGalleryImage(index) {
  if (!lightbox || !lightboxImage || !galleryImages.length) return;
  currentGalleryIndex = (index + galleryImages.length) % galleryImages.length;
  lightboxImage.src = galleryImages[currentGalleryIndex];
  if (lightboxCounter) {
    lightboxCounter.textContent = `${currentGalleryIndex + 1} / ${galleryImages.length}`;
  }
}

function openGalleryLightbox(index) {
  if (!lightbox) return;
  showGalleryImage(index);
  lightbox.classList.add('open');
  lightbox.setAttribute('aria-hidden', 'false');
  document.body.style.overflow = 'hidden';
}

function showPrevGalleryImage() {
  showGalleryImage(currentGalleryIndex - 1);
}

function showNextGalleryImage() {
  showGalleryImage(currentGalleryIndex + 1);
}

function bindHomeGalleryPreview() {
  if (!galleryGrid || !lightbox || !lightboxImage) return;
  refreshHomeGalleryImages();
  galleryGrid.querySelectorAll('.gallery-item').forEach((item, index) => {
    if (item.dataset.previewBound === 'true') return;
    item.dataset.previewBound = 'true';
    item.setAttribute('tabindex', '0');
    item.setAttribute('role', 'button');
    item.setAttribute('aria-label', 'Open nail design image');
    const openPreview = () => openGalleryLightbox(index);
    item.addEventListener('click', openPreview);
    item.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openPreview();
      }
    });
  });
}
bindHomeGalleryPreview();
document.addEventListener('golyn:gallery-rendered', bindHomeGalleryPreview);

function scrollToCurrentHash(behavior = 'auto') {
  if (!window.location.hash || window.location.hash === '#') return;
  const id = decodeURIComponent(window.location.hash.slice(1));
  const target = document.getElementById(id);
  if (!target) return;
  const navHeight = Number.parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--nav-h')) || 74;
  const top = Math.max(0, target.getBoundingClientRect().top + window.pageYOffset - navHeight);
  window.scrollTo({ top, left: 0, behavior });
}

function stabilizeInitialHashScroll() {
  const startedAt = Date.now();
  const refresh = () => {
    if (window.location.hash) requestAnimationFrame(() => scrollToCurrentHash('auto'));
  };
  refresh();
  setTimeout(refresh, 0);
  window.addEventListener('load', () => {
    refresh();
    setTimeout(refresh, 120);
    setTimeout(refresh, 450);
  }, { once: true });
  document.addEventListener('golyn:gallery-rendered', () => {
    if (Date.now() - startedAt < 2500) refresh();
  });
}

window.addEventListener('hashchange', () => {
  requestAnimationFrame(() => scrollToCurrentHash('smooth'));
});

function closeGalleryLightbox() {
  if (!lightbox || !lightboxImage) return;
  lightbox.classList.remove('open');
  lightbox.setAttribute('aria-hidden', 'true');
  lightboxImage.src = '';
  document.body.style.overflow = '';
}

if (lightboxClose) lightboxClose.addEventListener('click', closeGalleryLightbox);
if (lightboxPrev) lightboxPrev.addEventListener('click', (e) => {
  e.stopPropagation();
  showPrevGalleryImage();
});
if (lightboxNext) lightboxNext.addEventListener('click', (e) => {
  e.stopPropagation();
  showNextGalleryImage();
});
if (lightbox) {
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeGalleryLightbox();
  });
  lightbox.addEventListener('touchstart', (e) => {
    if (!lightbox.classList.contains('open')) return;
    touchStartX = e.changedTouches[0].clientX;
    touchStartY = e.changedTouches[0].clientY;
  }, { passive: true });
  lightbox.addEventListener('touchend', (e) => {
    if (!lightbox.classList.contains('open')) return;
    const touchEndX = e.changedTouches[0].clientX;
    const touchEndY = e.changedTouches[0].clientY;
    const deltaX = touchEndX - touchStartX;
    const deltaY = touchEndY - touchStartY;
    if (Math.abs(deltaX) < 45 || Math.abs(deltaX) < Math.abs(deltaY)) return;
    if (deltaX < 0) showNextGalleryImage();
    else showPrevGalleryImage();
  }, { passive: true });
}
document.addEventListener('keydown', (e) => {
  if (!lightbox || !lightbox.classList.contains('open')) return;
  if (e.key === 'Escape') closeGalleryLightbox();
  if (e.key === 'ArrowLeft') showPrevGalleryImage();
  if (e.key === 'ArrowRight') showNextGalleryImage();
});

function initHomePage() {
  const savedLang = localStorage.getItem('golynLang');
  setLang(i18n[savedLang] ? savedLang : 'ja');
  stabilizeInitialHashScroll();
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initHomePage);
} else {
  initHomePage();
}

</script>
</body>
