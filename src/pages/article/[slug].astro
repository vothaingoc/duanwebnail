---
import { getBlogPostsWithFallback } from '../../lib/sanity';

const golynArticles = await getBlogPostsWithFallback();

export async function getStaticPaths() {
  const articles = await getBlogPostsWithFallback();
  const seen = new Set();
  return articles
    .map((article) => String(article.slug || article.id || '').trim())
    .filter((slug) => slug && !seen.has(slug) && seen.add(slug))
    .map((slug) => ({ params: { slug } }));
}
