        id: { nav_gallery:'Galeri', price_eyebrow:'Harga', nav_services:'Layanan', nav_reviews:'Ulasan', acc_eyebrow:'Akses', staff_eyebrow:'Staf', nav_news:'Artikel', nav_reserve:'Reservasi', footer_desc:'Atelier nail premium di pusat Osaka. Teknik Jepang, gaya internasional.', footer_info:'Informasi', footer_about:'Tentang Kami', footer_price:'Harga', footer_contact:'Kontak', staff_title:'Profil Staf', staff_subtitle:'Kenali staf yang bekerja di Golyn Nail.', staff_members:'Nail Artist', staff_detail:'Lihat Detail', staff_experience:'Pengalaman', staff_specialty:'Keahlian', staff_certifications:'Sertifikasi', staff_gallery:'Galeri Desain', staff_back:'Kembali ke Staf' }
      };
      const langLabels = { ja:'日本語', en:'English', vi:'Tiếng Việt', zh:'中文', ko:'한국어', my:'မြန်မာ', id:'Bahasa Indonesia' };
      const langFlagClasses = { ja:'flag-ja', en:'flag-uk', vi:'flag-vi', zh:'flag-cn', ko:'flag-ko', my:'flag-my', id:'flag-id' };
      function toggleMenu() {
        const menu = document.getElementById('mobileNav');
        if (!menu) return;
        const isOpen = menu.classList.toggle('open');
        menu.setAttribute('aria-hidden', String(!isOpen));
        document.body.classList.toggle('mobile-nav-open', isOpen);
      }
      function closeLangMenus() {
        document.querySelectorAll('.lang-picker.open').forEach(picker => {
          picker.classList.remove('open');
          const button = picker.querySelector('.lang-current');
          if (button) button.setAttribute('aria-expanded', 'false');
        });
      }
      function toggleLangMenu(button) {
        const picker = button.closest('.lang-picker');
        const shouldOpen = picker && !picker.classList.contains('open');
        closeLangMenus();
        if (picker) picker.classList.toggle('open', shouldOpen);
        button.setAttribute('aria-expanded', String(shouldOpen));
      }
      function updateLangPickers(lang) {
        document.querySelectorAll('.lang-picker').forEach(picker => {
          const flag = picker.querySelector('.lang-current .flag');
          const label = picker.querySelector('.lang-current-label');
          if (flag) flag.className = `flag ${langFlagClasses[lang] || langFlagClasses.ja}`;
          if (label) label.textContent = langLabels[lang] || langLabels.ja;
          picker.querySelectorAll('[data-lang-option]').forEach(option => {
            option.classList.toggle('active', option.dataset.langOption === lang);
          });
        });
      }
      function setLang(lang) {
        if (!siteI18n[lang]) lang = 'ja';
        localStorage.setItem('golynLang', lang);
        document.documentElement.lang = { ja:'ja', en:'en', vi:'vi', zh:'zh', ko:'ko', my:'my', id:'id' }[lang] || 'ja';
        document.body.classList.add('lang-switching');
        setTimeout(() => {
          const dict = siteI18n[lang] || siteI18n.ja;
          document.querySelectorAll('[data-i18n]').forEach(el => {
            const key = el.getAttribute('data-i18n');
            if (dict[key] !== undefined) el.innerHTML = dict[key];
          });
          updateLangPickers(lang);
          document.body.classList.remove('lang-switching');
        }, 120);
      }
      function chooseLang(lang) {
        localStorage.setItem('golynLangUserSet', 'true');
        setLang(lang);
        closeLangMenus();
      }
      window.toggleMenu = toggleMenu;
      window.toggleLangMenu = toggleLangMenu;
      window.chooseLang = chooseLang;
      window.addEventListener('scroll', () => {
        const nav = document.getElementById('navbar');
        if (!nav) return;
        nav.style.boxShadow = window.scrollY > 40 ? '0 2px 24px rgba(74,55,40,.08)' : 'none';
      });
      document.addEventListener('DOMContentLoaded', () => setLang(localStorage.getItem('golynLang') || 'ja'));
      document.addEventListener('click', event => {
        if (!event.target.closest('.lang-picker')) closeLangMenus();
      });
    </script>
