---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site ?? 'https://duanwebnail.pages.dev').toString()} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@200;300;400;500&family=Noto+Sans+JP:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --cream: #F5EFE6;
        --cream-mid: #EDE0CC;
        --cream-deep: #D9C5A0;
        --beige: #C4975A;
        --beige-dark: #A0722A;
        --brown: #5C3D1E;
        --brown-deep: #2E1A08;
        --gold: #C9963C;
        --gold-light: #E8C97A;
        --text: #1C1008;
        --text-mid: #4A2E10;
        --text-light: #8B6830;
        --white: #FBF6EE;
        --serif: 'Cormorant Garamond', serif;
        --sans: 'Jost', 'Noto Sans JP', sans-serif;
        --nav-h: 74px;
      }
      html { scroll-behavior: smooth; }
      body {
        background: var(--cream);
        color: var(--text);
        font-family: var(--sans);
        font-weight: 300;
        line-height: 1.7;
        overflow-x: hidden;
      }
      a { color: inherit; }
      img { max-width: 100%; display: block; }
      nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        height: var(--nav-h);
        background: rgba(245,239,230,.96);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--cream-deep);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 40px;
        gap: 18px;
      }
      .nav-logo {
        font-family: var(--serif);
        font-size: 23px;
        letter-spacing: .12em;
        color: var(--brown-deep);
        text-decoration: none;
        white-space: nowrap;
      }
      .nav-logo span { color: var(--gold); font-style: italic; }
      .nav-links {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 1;
        gap: 26px;
        list-style: none;
      }
      .nav-links a {
        display: inline-block;
        font-size: 14px;
        font-weight: 400;
        letter-spacing: .12em;
        color: var(--text-mid);
        text-decoration: none;
        white-space: nowrap;
        transition: color .25s, transform .25s, text-shadow .25s;
      }
      .nav-links a:hover,
      .nav-links a[aria-current="page"] {
        color: var(--gold);
        transform: translateY(-2px);
        text-shadow: 0 4px 10px rgba(201,150,60,.25);
      }
      .nav-cta,
      .btn-primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 28px;
        background: var(--brown-deep);
        color: var(--cream);
        border-radius: 2px;
        text-decoration: none;
        font-size: 13px;
        letter-spacing: .14em;
        transition: background .25s, transform .25s, box-shadow .25s;
      }
      .nav-cta { border-radius: 999px; padding: 9px 22px; white-space: nowrap; }
      .nav-cta:hover,
      .btn-primary:hover {
        background: var(--brown);
        transform: translateY(-1px);
        box-shadow: 0 4px 18px rgba(201,150,60,.3);
      }
      .hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        padding: 6px;
        background: transparent;
        border: 0;
        cursor: pointer;
      }
      .hamburger span { width: 22px; height: 1.5px; background: var(--text); display: block; }
      .mobile-nav {
        position: fixed;
        inset: 0;
        z-index: 999;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 18px;
        height: 100vh;
        height: 100dvh;
        padding: calc(env(safe-area-inset-top, 0px) + 76px) 24px 32px;
        background: rgba(250,247,242,.98);
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: translateY(-8px);
        transition: opacity .22s ease, transform .22s ease, visibility .22s ease;
      }
      .mobile-nav.open { opacity: 1; visibility: visible; pointer-events: auto; transform: none; }
      .mobile-nav a {
        font-family: var(--serif);
        font-size: clamp(21px, 7vw, 32px);
        line-height: 1.16;
        font-weight: 300;
        color: var(--brown-deep);
        text-decoration: none;
        letter-spacing: .06em;
        text-align: center;
      }
      .mobile-nav-close {
        position: fixed;
        top: calc(env(safe-area-inset-top, 0px) + 18px);
        right: 22px;
        font-size: 22px;
        cursor: pointer;
        color: var(--text-mid);
        background: none;
        border: none;
      }
      body.mobile-nav-open { overflow: hidden; touch-action: none; }
      .page-hero {
        padding: calc(var(--nav-h) + 62px) 20px 54px;
        background: var(--white);
        text-align: center;
      }
      .hero-eyebrow {
        color: var(--gold);
        font-size: 12px;
        letter-spacing: .28em;
        text-transform: uppercase;
        margin-bottom: 14px;
      }
      .page-hero h1 {
        font-family: var(--serif);
        font-size: clamp(40px, 8vw, 68px);
        font-weight: 300;
        line-height: 1.12;
        color: var(--brown-deep);
      }
      .page-hero p {
        max-width: 660px;
        margin: 20px auto 0;
        color: var(--text-mid);
        font-size: 15px;
        letter-spacing: .04em;
      }
      .sec-line {
        width: 56px;
        height: 1.5px;
        background: var(--gold);
        margin: 22px auto 0;
        box-shadow: 0 0 8px rgba(201,150,60,.35);
      }
      main { min-height: 100vh; }
      footer { background: var(--brown-deep); padding: 40px 24px 26px; text-align: center; }
      .footer-logo {
        font-family: var(--serif);
        font-size: 24px;
        letter-spacing: .12em;
        color: var(--cream);
      }
      .footer-logo span { color: var(--gold-light); font-style: italic; }
      .footer-copy { margin-top: 14px; font-size: 13px; color: rgba(245,239,230,.38); }
      @media (max-width: 1100px) {
        nav { padding: 0 20px; }
        .nav-links, .nav-cta { display: none; }
        .hamburger { display: flex; }
      }
      @media (max-width: 600px) {
        nav { padding: 0 16px; }
        .nav-logo { font-size: 20px; }
        .page-hero { padding: calc(var(--nav-h) + 42px) 20px 42px; }
      }
    </style>
  </head>
  <body>
    <div class="mobile-nav" id="mobileNav" aria-hidden="true">
      <button class="mobile-nav-close" onclick="toggleMenu()" type="button">×</button>
      <a href="/#gallery" onclick="toggleMenu()">ギャラリー</a>
      <a href="/#pricing" onclick="toggleMenu()">料金表</a>
      <a href="/#services" onclick="toggleMenu()">サービス</a>
      <a href="/#testimonials" onclick="toggleMenu()">口コミ</a>
      <a href="/#access" onclick="toggleMenu()">アクセス</a>
      <a href="/staff/" onclick="toggleMenu()">スタッフ</a>
      <a href="/news/" onclick="toggleMenu()">コラム</a>
      <a class="btn-primary" href="/#access" onclick="toggleMenu()">ご予約</a>
    </div>
    <nav id="navbar">
      <a class="nav-logo" href="/">Golyn <span>Nail</span></a>
      <ul class="nav-links">
        <li><a href="/#gallery">ギャラリー</a></li>
        <li><a href="/#pricing">料金表</a></li>
        <li><a href="/#services">サービス</a></li>
        <li><a href="/#testimonials">口コミ</a></li>
        <li><a href="/#access">アクセス</a></li>
        <li><a href="/staff/" aria-current={Astro.url.pathname.startsWith('/staff') ? 'page' : undefined}>スタッフ</a></li>
        <li><a href="/news/">コラム</a></li>
      </ul>
      <a class="nav-cta" href="/#access">ご予約</a>
      <button class="hamburger" type="button" onclick="toggleMenu()" aria-label="メニューを開く">
        <span></span><span></span><span></span>
      </button>
    </nav>
    <slot />
    <footer>
      <div class="footer-logo">Golyn <span>Nail</span></div>
      <p class="footer-copy">© 2026 Golyn Nail. All rights reserved.</p>
    </footer>
    <script is:inline>
      function toggleMenu() {
        const menu = document.getElementById('mobileNav');
        if (!menu) return;
        const isOpen = menu.classList.toggle('open');
        menu.setAttribute('aria-hidden', String(!isOpen));
        document.body.classList.toggle('mobile-nav-open', isOpen);
      }
      window.addEventListener('scroll', () => {
        const nav = document.getElementById('navbar');
        if (!nav) return;
        nav.style.boxShadow = window.scrollY > 40 ? '0 2px 24px rgba(74,55,40,.08)' : 'none';
      });
    </script>
  </body>
</html>
